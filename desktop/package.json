{
  "name": "restos-desktop",
  "version": "1.5.275",
  "description": "RestOS Desktop — POS система для ресторанов",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-frontend": "cd .. && npx vite build && rm -rf desktop/frontend && cp -r dist desktop/frontend",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "release": "cd .. && npx vite build && cd desktop && rm -rf frontend && cp -r ../dist frontend && git add -A && git commit -m \"update: new release\" && git push"
  },
  "build": {
    "appId": "tj.restos.pos",
    "productName": "RestOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "api-server.js",
      "db.js",
      "sync.js",
      "activate.html",
      "blocked.html",
      "frontend/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RestOS"
    },
    "publish": {
      "provider": "github",
      "owner": "beckortikov",
      "repo": "restos-desktop"
    }
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.15",
    "@sentry/node": "^10.48.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.3.9",
    "express": "^4.21.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
