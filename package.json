{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:next": "next dev",
    "build:next": "next build",
    "build-desktop": "vite build && cd desktop && node -e \"const p=require('./package.json');const v=p.version.split('.');v[2]=+v[2]+1;p.version=v.join('.');require('fs').writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\" && rm -rf frontend && cp -r ../dist frontend",
    "waiter:apk": "cd android-kotlin && JAVA_HOME=\"${JAVA_HOME:-/Applications/Android Studio.app/Contents/jbr/Contents/Home}\" ./gradlew assembleRelease && echo '\\n✓ APK ready: android-kotlin/app/build/outputs/apk/release/app-release.apk'",
    "waiter:apk-debug": "cd android-kotlin && JAVA_HOME=\"${JAVA_HOME:-/Applications/Android Studio.app/Contents/jbr/Contents/Home}\" ./gradlew assembleDebug && echo '\\n✓ APK ready: android-kotlin/app/build/outputs/apk/debug/app-debug.apk'",
    "desktop:standalone": "node desktop/standalone.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:perf": "playwright test --project=perf"
  },
